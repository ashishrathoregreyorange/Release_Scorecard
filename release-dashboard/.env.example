# Copy to .env and fill in. The server reads these via dotenv.

# JIRA — leave blank to disable JIRA sync entirely.
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=DHL,WMS,RBC
JIRA_POLL_INTERVAL_MS=300000

# Server
DASHBOARD_PORT=3000

# Optional: where the JSON store lives. Defaults to ./data/store.json
STORE_PATH=./data/store.json
