# Copy to .env and fill in. The server reads these via dotenv.

# JIRA — leave blank to disable JIRA sync entirely.
JIRA_BASE_URL=https://greyorange-work.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=DHL,WMS,RBC
JIRA_POLL_INTERVAL_MS=300000

# Optional: re-use an existing JIRA filter rather than building JQL from the
# project key. To find the ID: open the dashboard gadget, click "View this
# filter" — the URL becomes /issues/?filter=12345.
# (Dashboard 12599 / gadget 26873 wraps the filter you want.)
JIRA_FILTER_ID=

# Optional: raw JQL template instead. Supports the {fixVersion} placeholder.
#   JIRA_JQL=project = DHL AND issuetype = Bug AND fixVersion = "{fixVersion}"
JIRA_JQL=

# Server
DASHBOARD_PORT=3000

# Optional: where the JSON store lives. Defaults to ./data/store.json
STORE_PATH=./data/store.json
