{
  "name": "release-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Release scorecard dashboard — CSV + JIRA ingestion, scoring, React frontend, PDF export.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"node server/index.js\" \"vite\"",
    "ingest": "node scripts/ingestCSV.js --dir ./data",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "server": "node server/index.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "papaparse": "^5.4.1",
    "puppeteer": "^23.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}
